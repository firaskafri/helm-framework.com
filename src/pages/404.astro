---
import { SITE_NAME } from '../data/site';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Page not found"
  description={`The page you requested does not exist on ${SITE_NAME}.`}
  noindex
>
  <Nav />
  <main id="main-content" class="flex-1 flex flex-col items-center justify-center px-6 py-32 text-center">
    <p class="text-sm font-semibold uppercase tracking-wider text-[var(--color-terracotta)] mb-4">404</p>
    <h1 class="font-[var(--font-serif)] text-3xl md:text-4xl font-semibold text-[var(--color-ink)] mb-4">
      Page not found
    </h1>
    <p class="text-[var(--color-ink-light)] max-w-md mb-8">
      That URL may have moved or never existed. Start from the home page or open a guide from the navigation.
    </p>
    <a
      href="/"
      class="inline-flex items-center px-5 py-2.5 rounded-lg text-sm font-medium bg-[var(--color-terracotta)] text-[var(--color-cream)] no-underline hover:bg-[var(--color-terracotta-light)] transition-colors"
    >
      Back to home
    </a>
  </main>
  <Footer />
</Base>
