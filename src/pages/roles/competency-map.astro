---
import { getCollection } from 'astro:content';
import { resolveSiteOrigin } from '../../lib/resolveSiteOrigin';
import { buildBreadcrumbList, buildWebPageJsonLd } from '../../lib/jsonLd';
import { toRoleView } from '../../lib/competencyMap';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import CompetencyRolePanel from '../../components/CompetencyRolePanel.astro';
import Footer from '../../components/Footer.astro';

const allRoles = await getCollection('roles');
const roles = [...allRoles].sort((a, b) => a.data.order - b.data.order);
const rolesView = roles.map(toRoleView);

const pageTitle = 'Competency Evolution Explorer';
const pageDescription =
  'Interactive mapping between traditional role competencies and AI-era competencies — what evolves, what is new, and what to sunset, per role.';

const siteOrigin = resolveSiteOrigin(Astro.site, Astro.url);
const homeUrl = new URL('/', siteOrigin).href;
const rolesIndexUrl = new URL('/roles', siteOrigin).href;
const pageUrl = new URL(Astro.url.pathname, siteOrigin).href;

const jsonLd = [
  buildBreadcrumbList([
    { name: 'Home', url: homeUrl },
    { name: 'Roles', url: rolesIndexUrl },
    { name: pageTitle, url: pageUrl },
  ]),
  buildWebPageJsonLd({ headline: pageTitle, description: pageDescription, url: pageUrl, homeUrl }),
];
---

<Base
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
>
  <Nav />

  <main id="main-content">
  <section class="pt-32 pb-14 md:pt-40 md:pb-16 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="text-[var(--color-terracotta)] font-medium text-sm tracking-widest uppercase mb-6">
        Interactive Tool
      </p>
      <h1 class="font-[var(--font-serif)] text-[clamp(2rem,5vw,3.5rem)] font-semibold leading-[1.1] tracking-tight text-[var(--color-ink)] mb-5">
        {pageTitle}
      </h1>
      <p class="text-lg md:text-xl text-[var(--color-ink-light)] leading-relaxed max-w-2xl font-light">
        See how each role's competencies transform in the AI era — what carries over, what's entirely new, and what's no longer relevant.
      </p>
    </div>
  </section>

  <div class="ce-tabs-rail">
    <div class="max-w-5xl mx-auto px-6">
      <div class="ce-tabs-scroll" id="ce-tabs" role="tablist" aria-label="Select a role">
        {rolesView.map((r, i) => (
          <button
            type="button"
            role="tab"
            id={`ce-tab-${r.id}`}
            aria-controls={`ce-panel-${r.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            tabindex={i === 0 ? 0 : -1}
            class:list={[
              'ce-tab',
              r.category === 'engineering' ? 'ce-tab-eng' : 'ce-tab-prod',
              i === 0 && 'ce-tab-active',
            ]}
            data-id={r.id}
          >
            {r.fromTitle}
          </button>
        ))}
      </div>
    </div>
  </div>

  <section class="px-6 pt-10 pb-20">
    <div class="max-w-5xl mx-auto" id="ce-content">
      {rolesView.map((role, i) => (
        <CompetencyRolePanel role={role} index={i} />
      ))}
    </div>
  </section>
  </main>

  <Footer />
</Base>

<script>
  const tabs = document.getElementById('ce-tabs');
  const content = document.getElementById('ce-content');
  if (tabs && content) {
    const panels = content.querySelectorAll<HTMLElement>('.ce-role');
    const buttons = [...tabs.querySelectorAll<HTMLButtonElement>('.ce-tab')];

    let activeId = panels[0]?.dataset.role ?? '';
    const hash = window.location.hash.replace('#', '');
    if (hash && content.querySelector(`[data-role="${hash}"]`)) activeId = hash;

    function activate(id: string) {
      panels.forEach((p) => {
        p.hidden = p.dataset.role !== id;
      });
      buttons.forEach((b) => {
        const on = b.dataset.id === id;
        b.classList.toggle('ce-tab-active', on);
        b.setAttribute('aria-selected', String(on));
        b.tabIndex = on ? 0 : -1;
      });
    }

    activate(activeId);

    tabs.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.ce-tab');
      if (!btn || btn.dataset.id === activeId) return;
      activeId = btn.dataset.id!;
      window.location.hash = activeId;
      activate(activeId);
      btn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    });

    tabs.addEventListener('keydown', (e) => {
      const key = (e as KeyboardEvent).key;
      const current = buttons.findIndex((b) => b.dataset.id === activeId);
      let next = -1;

      if (key === 'ArrowRight') next = (current + 1) % buttons.length;
      else if (key === 'ArrowLeft') next = (current - 1 + buttons.length) % buttons.length;
      else if (key === 'Home') next = 0;
      else if (key === 'End') next = buttons.length - 1;
      else return;

      e.preventDefault();
      const btn = buttons[next];
      activeId = btn.dataset.id!;
      window.location.hash = activeId;
      activate(activeId);
      btn.focus();
      btn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
    });
  }
</script>

<style is:global>
  .ce-tabs-rail {
    position: sticky;
    top: 4rem;
    z-index: 38;
    background: color-mix(in srgb, var(--color-cream) 92%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }
  .ce-tabs-scroll {
    display: flex;
    gap: 0.4rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 2px;
  }
  .ce-tabs-scroll::-webkit-scrollbar { display: none; }

  .ce-tab {
    flex-shrink: 0;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    border: 1.5px solid var(--color-border);
    background: white;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-ink-light);
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .ce-tab:hover {
    border-color: var(--color-muted);
    color: var(--color-ink);
  }
  .ce-tab-active.ce-tab-eng {
    background: var(--color-terracotta);
    border-color: var(--color-terracotta);
    color: white;
  }
  .ce-tab-active.ce-tab-prod {
    background: var(--color-steel);
    border-color: var(--color-steel);
    color: white;
  }

  .ce-header {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2rem 2rem 1.5rem;
    margin-bottom: 2.5rem;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04), 0 4px 24px rgba(0,0,0,0.03);
  }
  h2.ce-header-top {
    margin: 0 0 1rem;
    font: inherit;
    font-weight: inherit;
  }

  .ce-header-top {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .ce-header-from, .ce-header-to { flex: 1; min-width: 140px; }
  .ce-header-to { text-align: right; }
  .ce-header-arrow { flex-shrink: 0; }
  .ce-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 0.25rem;
  }
  .ce-header-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-ink);
  }
  .ce-header-aliases {
    display: block;
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-top: 0.2rem;
  }
  .ce-header-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-ink-light);
    margin: 0 0 1.5rem;
    line-height: 1.5;
  }

  .ce-stats {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .ce-stat {
    flex: 1;
    text-align: center;
    padding: 0.75rem 0.5rem;
    background: var(--color-cream);
    border-radius: 10px;
  }
  .ce-stat-num {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .ce-stat-evolved { color: var(--color-terracotta); }
  .ce-stat-gap { color: var(--color-steel); }
  .ce-stat-dep { color: var(--color-muted); }
  .ce-stat-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
  }

  .ce-gap-wrap { margin-bottom: 1.25rem; }
  .ce-gap-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-muted);
    margin-bottom: 0.35rem;
  }
  .ce-gap-labels-pct {
    margin-bottom: 0;
    margin-top: 0.35rem;
    font-weight: 600;
  }
  .ce-gap-labels-pct span:first-child { color: var(--color-terracotta); }
  .ce-gap-labels-pct span:last-child { color: var(--color-steel); }
  .ce-gap-bar {
    display: flex;
    height: 10px;
    border-radius: 99px;
    overflow: hidden;
    background: var(--color-cream-dark);
    gap: 2px;
  }
  .ce-gap-bar-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .ce-gap-bar-evolved { background: var(--color-terracotta); }
  .ce-gap-bar-new { background: var(--color-steel); }

  .ce-jd-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-terracotta);
    text-decoration: none;
    transition: color 0.15s;
  }
  .ce-jd-link:hover { color: var(--color-terracotta-light); }

  .ce-section { margin-bottom: 2.5rem; }
  .ce-section-head { margin-bottom: 1.25rem; }
  .ce-section-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.65rem;
    border-radius: 6px;
    margin-bottom: 0.5rem;
  }
  .ce-badge-evolved { background: color-mix(in srgb, var(--color-terracotta) 12%, transparent); color: var(--color-terracotta); }
  .ce-badge-gap { background: color-mix(in srgb, var(--color-steel) 12%, transparent); color: var(--color-steel); }
  .ce-badge-dep { background: color-mix(in srgb, var(--color-muted) 15%, transparent); color: var(--color-muted); }
  .ce-section-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.3rem;
  }
  .ce-section-desc {
    font-size: 0.88rem;
    color: var(--color-ink-light);
    margin: 0;
    line-height: 1.55;
  }

  .ce-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .ce-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem 1.35rem;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    animation: ce-slideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .ce-card:hover {
    border-color: color-mix(in srgb, var(--color-border) 50%, var(--color-terracotta));
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    transform: translateY(-2px);
  }
  .ce-card-evolved { border-left: 3px solid var(--color-terracotta); }
  .ce-card-gap { border-left: 3px solid var(--color-steel); }

  .ce-card-was {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .ce-card-was-label {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    flex-shrink: 0;
    padding: 0.15rem 0.4rem;
    background: var(--color-cream-dark);
    border-radius: 4px;
  }
  .ce-card-was-text {
    font-size: 0.88rem;
    color: var(--color-muted);
    line-height: 1.4;
  }

  .ce-card-arrow-down {
    display: flex;
    align-items: center;
    padding: 0.15rem 0 0.15rem 1.8rem;
  }

  .ce-card-now-label {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-terracotta);
    padding: 0.15rem 0.4rem;
    background: color-mix(in srgb, var(--color-terracotta) 8%, transparent);
    border-radius: 4px;
    margin-bottom: 0.35rem;
  }
  .ce-card-now-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }
  .ce-card-now-desc {
    font-size: 0.85rem;
    color: var(--color-ink-light);
    line-height: 1.55;
    margin: 0;
  }

  .ce-card-gap-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.5rem;
  }
  .ce-card-gap-badge {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: white;
    background: var(--color-steel);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .ce-card-gap:hover {
    border-color: color-mix(in srgb, var(--color-border) 50%, var(--color-steel));
  }

  .ce-dep-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ce-dep-item {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    padding: 0.75rem 1rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-size: 0.88rem;
    color: var(--color-muted);
    line-height: 1.5;
    animation: ce-slideUp 0.35s cubic-bezier(0.22, 1, 0.36, 1) both;
    transition: background-color 0.15s;
  }
  .ce-dep-item:hover { background: var(--color-cream-dark); }
  .ce-dep-x {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--color-muted-light);
  }

  @keyframes ce-slideUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .ce-header { padding: 1.25rem; }
    .ce-header-top { gap: 0.75rem; }
    .ce-header-title { font-size: 1.1rem; }
    .ce-header-to { text-align: left; }
    .ce-header-arrow { transform: rotate(90deg); }
    .ce-stats { gap: 0.5rem; }
    .ce-stat { padding: 0.6rem 0.35rem; }
    .ce-stat-num { font-size: 1.3rem; }
    .ce-cards { grid-template-columns: 1fr; }
    .ce-card { padding: 1rem; }
    .ce-tab { font-size: 0.75rem; padding: 0.4rem 0.8rem; }
  }
</style>
