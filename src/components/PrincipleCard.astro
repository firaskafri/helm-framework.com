---
interface Props {
  number: number;
  title: string;
  quote: string;
}

const { number, title, quote } = Astro.props;
const slug = `principle-${number}-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;
---

<a href={`/foundation#${slug}`} class="group no-underline flex flex-1">
  <article class="flex-1 p-6 md:p-8 rounded-lg shadow-[0_1px_3px_rgba(0,0,0,0.08)] hover:shadow-[0_4px_12px_rgba(0,0,0,0.1)] transition-shadow bg-white">
    <span class="font-[var(--font-serif)] text-5xl font-light text-[var(--color-muted-light)] leading-none">
      {String(number).padStart(2, '0')}
    </span>
    <h3 class="font-[var(--font-serif)] text-lg font-semibold text-[var(--color-ink)] mt-4 mb-3 group-hover:text-[var(--color-terracotta)] transition-colors">
      {title}
    </h3>
    <p class="text-[var(--color-ink-light)] text-sm leading-relaxed">
      {quote}
    </p>
  </article>
</a>
