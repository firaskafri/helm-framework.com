---
import { MATURITY_LEVELS } from '../data/practitioners';

interface Props {
  variant?: 'full' | 'compact';
}

const { variant = 'full' } = Astro.props;
const levels = MATURITY_LEVELS;
---

<div class="ms-wrap" id={variant === 'compact' ? 'maturity-stepper-compact' : 'maturity-stepper'} data-variant={variant}>
  <div class="ms-stepper" role="tablist" aria-label="Maturity levels">
    <div class="ms-track" aria-hidden="true">
      <div class="ms-track-fill" />
    </div>
    {levels.map((lvl, i) => (
      <button
        class:list={['ms-node', i === 0 && 'ms-node-active']}
        type="button"
        role="tab"
        id={`ms-tab-${variant}-${lvl.level}`}
        aria-controls={`ms-panel-${variant}-${lvl.level}`}
        aria-selected={i === 0 ? 'true' : 'false'}
        tabindex={i === 0 ? 0 : -1}
        data-level={lvl.level}
        style={`--i:${i}`}
      >
        <span class="ms-node-circle">{lvl.level}</span>
        <span class="ms-node-label">{lvl.name}</span>
      </button>
    ))}
  </div>

  {levels.map((lvl, i) => (
    <div
      class="ms-panel"
      id={`ms-panel-${variant}-${lvl.level}`}
      role="tabpanel"
      aria-labelledby={`ms-tab-${variant}-${lvl.level}`}
      data-level={lvl.level}
      hidden={i !== 0}
    >
      <div class="ms-panel-head">
        <div class="ms-panel-title-row">
          <span class="helm-badge">Level {lvl.level}</span>
          <h4 class="ms-panel-title">{lvl.name}</h4>
        </div>
        <p class="ms-panel-desc">{lvl.description}</p>
      </div>

      <div class="ms-signal">
        <svg class="ms-signal-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
        <span>{lvl.signal}</span>
      </div>

      {variant === 'full' && (
        <>
          <div class="ms-section">
            <h5 class="helm-label ms-section-title">Dimensions</h5>
            <div class="ms-dimensions">
              {lvl.dimensions.map((d) => (
                <div class="ms-dim">
                  <span class="ms-dim-label">{d.dimension}</span>
                  <span class="ms-dim-value">{d.details}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="ms-section">
            <h5 class="helm-label ms-section-title">Assessment Criteria</h5>
            <ul class="ms-criteria">
              {lvl.assessmentCriteria.map((c) => (
                <li>
                  <svg class="ms-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-terracotta)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  <span>{c}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="ms-failure">
            <svg class="ms-failure-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
              <line x1="12" y1="9" x2="12" y2="13" />
              <line x1="12" y1="17" x2="12.01" y2="17" />
            </svg>
            <div>
              <span class="ms-failure-label">Failure mode</span>
              <span class="ms-failure-text">{lvl.failureMode}</span>
            </div>
          </div>
        </>
      )}

      {variant === 'compact' && (
        <a href="/practitioners#maturity-model" class="ms-link">
          See full maturity model with dimensions, criteria, and failure modes
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </div>
  ))}
</div>

<script>
  import { observeEntrance } from '../lib/observeEntrance';

  document.querySelectorAll<HTMLElement>('.ms-wrap').forEach((wrap) => {
    const nodes = wrap.querySelectorAll<HTMLButtonElement>('.ms-node');
    const panels = wrap.querySelectorAll<HTMLElement>('.ms-panel');
    const trackFill = wrap.querySelector<HTMLElement>('.ms-track-fill');
    let activeIdx = 0;

    function activate(idx: number) {
      activeIdx = idx;
      nodes.forEach((n, i) => {
        const on = i === idx;
        n.classList.toggle('ms-node-active', on);
        n.classList.toggle('ms-node-past', i < idx);
        n.setAttribute('aria-selected', String(on));
        n.tabIndex = on ? 0 : -1;
      });
      panels.forEach((p) => {
        p.hidden = Number(p.dataset.level) !== idx + 1;
      });
      if (trackFill) {
        const progress = nodes.length > 1 ? (idx / (nodes.length - 1)) * 100 : 0;
        trackFill.style.width = `${progress}%`;
      }
    }

    nodes.forEach((n, i) => {
      n.addEventListener('click', () => activate(i));
      n.addEventListener('keydown', (e: KeyboardEvent) => {
        let next = activeIdx;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          next = Math.min(activeIdx + 1, nodes.length - 1);
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          next = Math.max(activeIdx - 1, 0);
        } else return;
        e.preventDefault();
        activate(next);
        nodes[next].focus();
      });
    });

    activate(0);
    observeEntrance(wrap.id, 'ms-visible');
  });
</script>

<style>
  .ms-wrap {
    margin: 2rem 0;
  }

  .ms-stepper {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    position: relative;
    margin-bottom: 1.5rem;
    padding: 0 0.5rem;
  }

  .ms-track {
    position: absolute;
    top: 18px;
    left: 36px;
    right: 36px;
    height: 3px;
    background: var(--color-border);
    border-radius: 2px;
    z-index: 0;
  }

  .ms-track-fill {
    height: 100%;
    background: var(--color-terracotta);
    border-radius: 2px;
    width: 0;
    transition: width 0.4s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .ms-track-fill {
      transition: none;
    }
  }

  .ms-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1;
    outline: none;
    opacity: 0;
    transform: translateY(6px);
  }

  .ms-visible .ms-node {
    animation: helm-slideUp 0.35s var(--ease-out-quart) both;
    animation-delay: calc(var(--i) * 70ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .ms-node {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
  }

  .ms-node-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2.5px solid var(--color-border);
    background: white;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-muted);
    transition: all 0.25s ease;
  }

  .ms-node:hover .ms-node-circle {
    border-color: var(--color-terracotta-light);
    color: var(--color-terracotta-light);
  }

  .ms-node:focus-visible .ms-node-circle {
    outline: 2px solid var(--color-terracotta);
    outline-offset: 3px;
  }

  .ms-node-past .ms-node-circle {
    border-color: var(--color-terracotta);
    background: color-mix(in srgb, var(--color-terracotta) 10%, white);
    color: var(--color-terracotta);
  }

  .ms-node-active .ms-node-circle {
    border-color: var(--color-terracotta);
    background: var(--color-terracotta);
    color: white;
    transform: scale(1.1);
  }

  .ms-node-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    transition: color 0.2s ease;
    text-align: center;
    max-width: 80px;
  }

  .ms-node-active .ms-node-label {
    color: var(--color-terracotta);
  }

  /* Panel */
  .ms-panel {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
    animation: helm-panelIn 0.3s ease both;
  }

  .ms-panel[hidden] { display: none; }

  @media (prefers-reduced-motion: reduce) {
    .ms-panel { animation: none; }
  }

  .ms-panel-head {
    margin-bottom: 1rem;
  }

  .ms-panel-title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .ms-panel-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0;
  }

  .ms-panel-desc {
    font-size: 0.95rem;
    color: var(--color-ink-light);
    line-height: 1.6;
    margin: 0;
  }

  .ms-signal {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    background: var(--color-cream);
    border-radius: 8px;
    border-left: 3px solid var(--color-terracotta);
    margin-bottom: 1.25rem;
  }

  .ms-signal-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--color-terracotta);
  }

  .ms-signal span {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-ink-light);
    line-height: 1.5;
  }

  .ms-section {
    margin-bottom: 1.25rem;
  }

  .ms-section-title {
    margin-bottom: 0.75rem;
  }

  .ms-dimensions {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .ms-dim {
    display: flex;
    padding: 0.6rem 0.85rem;
    font-size: 0.88rem;
    border-bottom: 1px solid var(--color-border);
  }

  .ms-dim:last-child {
    border-bottom: none;
  }

  .ms-dim:nth-child(even) {
    background: var(--color-stripe);
  }

  .ms-dim-label {
    flex-shrink: 0;
    width: 130px;
    font-weight: 600;
    color: var(--color-ink);
  }

  .ms-dim-value {
    color: var(--color-ink-light);
    line-height: 1.5;
  }

  .ms-criteria {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ms-criteria li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--color-ink);
    line-height: 1.5;
  }

  .ms-check {
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .ms-failure {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    background: color-mix(in srgb, var(--color-terracotta) 5%, white);
    border: 1px solid color-mix(in srgb, var(--color-terracotta) 20%, var(--color-border));
    border-radius: 8px;
  }

  .ms-failure-icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: var(--color-terracotta);
  }

  .ms-failure-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-terracotta);
    margin-bottom: 0.2rem;
  }

  .ms-failure-text {
    font-size: 0.88rem;
    color: var(--color-ink-light);
    line-height: 1.5;
  }

  .ms-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-terracotta);
    text-decoration: none;
    transition: color 0.15s;
  }

  .ms-link:hover {
    color: var(--color-terracotta-light);
  }

  @media (max-width: 640px) {
    .ms-stepper {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      gap: 0.25rem;
      padding: 0;
    }

    .ms-stepper::-webkit-scrollbar { display: none; }

    .ms-track {
      left: 18px;
      right: 18px;
    }

    .ms-node-label {
      font-size: 0.62rem;
      max-width: 60px;
    }

    .ms-panel {
      padding: 1.25rem;
    }

    .ms-dim {
      flex-direction: column;
      gap: 0.2rem;
    }

    .ms-dim-label {
      width: auto;
      font-size: 0.78rem;
    }
  }
</style>
