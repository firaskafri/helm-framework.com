---
import { ORG_SHIFTS } from '../data/leadership';

interface Props {}

const shifts = ORG_SHIFTS;
---

<div class="os-wrap" id="org-shift">
  <div class="os-diagram">
    <div class="os-panel os-panel-before">
      <span class="os-panel-label">Before <span class="os-panel-sublabel">(Horizontal Silos)</span></span>
      <div class="os-flow-h">
        <div class="os-node os-node-start">Product</div>
        <svg class="os-flow-arrow" width="24" height="16" viewBox="0 0 24 16" aria-hidden="true">
          <path d="M0,8 L20,8 M16,3 L21,8 L16,13" fill="none" stroke="var(--color-muted-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="os-node">Frontend</div>
        <svg class="os-flow-arrow" width="24" height="16" viewBox="0 0 24 16" aria-hidden="true">
          <path d="M0,8 L20,8 M16,3 L21,8 L16,13" fill="none" stroke="var(--color-muted-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="os-node">Backend</div>
        <svg class="os-flow-arrow" width="24" height="16" viewBox="0 0 24 16" aria-hidden="true">
          <path d="M0,8 L20,8 M16,3 L21,8 L16,13" fill="none" stroke="var(--color-muted-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="os-node">QA</div>
        <svg class="os-flow-arrow" width="24" height="16" viewBox="0 0 24 16" aria-hidden="true">
          <path d="M0,8 L20,8 M16,3 L21,8 L16,13" fill="none" stroke="var(--color-muted-light)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <div class="os-node">DevOps</div>
      </div>
      <p class="os-handoff-note">Handoff delays between teams</p>
    </div>

    <div class="os-divider" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
        <circle cx="20" cy="20" r="19" stroke="var(--color-terracotta)" stroke-width="1.5" stroke-dasharray="3 3" opacity="0.4" />
        <path d="M15 20H25M25 20L21 16M25 20L21 24" stroke="var(--color-terracotta)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>

    <div class="os-panel os-panel-after">
      <span class="os-panel-label">After <span class="os-panel-sublabel">(Vertical Pods)</span></span>
      <div class="os-pods">
        {['A', 'B', 'C'].map((letter) => (
          <div class="os-pod">
            <span class="os-pod-label">Pod {letter}</span>
            <div class="os-pod-members">
              <span class="os-pod-role os-role-product">PM</span>
              <span class="os-pod-role os-role-product">Designer</span>
              <span class="os-pod-role os-role-eng">Architect</span>
              <span class="os-pod-role os-role-eng">Engineers</span>
              <span class="os-pod-role os-role-agent">Agent</span>
            </div>
            <svg class="os-pod-arrow" width="16" height="24" viewBox="0 0 16 24" aria-hidden="true">
              <path d="M8,0 L8,20 M3,16 L8,21 L13,16" fill="none" stroke="var(--color-terracotta)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="os-pod-output">Feature {letter}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="os-shifts">
    {shifts.map((shift, i) => (
      <article class="os-shift-card" style={`--i:${i}`}>
        <span class="os-shift-num">{String(shift.number).padStart(2, '0')}</span>
        <div>
          <h4 class="os-shift-title">{shift.title}</h4>
          <p class="os-shift-desc">{shift.description}</p>
        </div>
      </article>
    ))}
  </div>
</div>

<script>
  import { observeEntrance } from '../lib/observeEntrance';
  observeEntrance('org-shift', 'os-visible', 0.1);
</script>

<style>
  .os-wrap {
    margin: 2rem 0;
  }

  .os-diagram {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin-bottom: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    background: white;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .os-panel {
    flex: 1;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .os-panel-before {
    background: var(--color-cream);
    opacity: 0;
    transform: translateX(-12px);
  }

  .os-panel-after {
    opacity: 0;
    transform: translateX(12px);
  }

  .os-visible .os-panel-before {
    animation: os-slideRight 0.5s var(--ease-out-quart) 0.1s both;
  }

  .os-visible .os-panel-after {
    animation: os-slideLeft 0.5s var(--ease-out-quart) 0.3s both;
  }

  @keyframes os-slideRight {
    from { opacity: 0; transform: translateX(-12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes os-slideLeft {
    from { opacity: 0; transform: translateX(12px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .os-panel-before,
    .os-panel-after {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
  }

  .os-panel-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ink);
  }

  .os-panel-sublabel {
    color: var(--color-muted);
    font-weight: 500;
  }

  .os-flow-h {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .os-node {
    padding: 0.4rem 0.65rem;
    border: 1.5px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-ink-light);
    background: white;
    white-space: nowrap;
  }

  .os-node-start {
    border-color: var(--color-muted);
    color: var(--color-ink);
  }

  .os-flow-arrow {
    flex-shrink: 0;
  }

  .os-handoff-note {
    font-size: 0.72rem;
    color: var(--color-muted);
    font-style: italic;
    margin: 0;
  }

  .os-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.5rem;
    flex-shrink: 0;
  }

  .os-pods {
    display: flex;
    gap: 0.75rem;
    width: 100%;
    justify-content: center;
  }

  .os-pod {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    flex: 1;
    max-width: 120px;
  }

  .os-pod-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-terracotta);
  }

  .os-pod-members {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    width: 100%;
  }

  .os-pod-role {
    display: block;
    text-align: center;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .os-role-product {
    background: color-mix(in srgb, var(--color-steel) 12%, transparent);
    color: var(--color-steel);
  }

  .os-role-eng {
    background: color-mix(in srgb, var(--color-terracotta) 10%, transparent);
    color: var(--color-terracotta);
  }

  .os-role-agent {
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .os-pod-arrow {
    flex-shrink: 0;
  }

  .os-pod-output {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  /* Shift cards */
  .os-shifts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
  }

  .os-shift-card {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    opacity: 0;
    transform: translateY(8px);
  }

  .os-visible .os-shift-card {
    animation: helm-slideUp 0.35s var(--ease-out-quart) both;
    animation-delay: calc(var(--i) * 60ms + 400ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .os-shift-card {
      opacity: 1;
      transform: none;
      animation: none !important;
    }
  }

  .os-shift-card:hover {
    border-color: color-mix(in srgb, var(--color-border) 50%, var(--color-terracotta));
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .os-shift-num {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 300;
    color: var(--color-muted-light);
    line-height: 1;
    flex-shrink: 0;
  }

  .os-shift-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 0.4rem;
    line-height: 1.3;
  }

  .os-shift-desc {
    font-size: 0.85rem;
    color: var(--color-ink-light);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 640px) {
    .os-diagram {
      flex-direction: column;
    }

    .os-divider {
      padding: 0.5rem 0;
    }

    .os-divider svg {
      transform: rotate(90deg);
    }

    .os-flow-arrow {
      display: none;
    }

    .os-flow-h {
      gap: 0.25rem;
    }

    .os-shifts {
      grid-template-columns: 1fr;
    }

    .os-panel {
      padding: 1.25rem;
    }
  }
</style>
